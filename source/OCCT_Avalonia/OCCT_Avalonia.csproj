<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
	<ApplicationManifest>app.manifest</ApplicationManifest>
	<PlatformTarget>x64</PlatformTarget>
  </PropertyGroup>
<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
	<AppendTargetFrameworkToOutputPath>output</AppendTargetFrameworkToOutputPath>
	<OutputPath>..\..\build\Debug</OutputPath>
</PropertyGroup>
<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<AppendTargetFrameworkToOutputPath>output</AppendTargetFrameworkToOutputPath>
		<OutputPath>..\..\build\Release</OutputPath>
</PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.11" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.11" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.11" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.11" />
    <!--Condition below is needed to remove Avalonia.Diagnostics package from build output in Release configuration.-->
    <PackageReference Include="Avalonia.Diagnostics" Version="11.3.11">
      <IncludeAssets Condition="'$(Configuration)' != 'Debug'">None</IncludeAssets>
      <PrivateAssets Condition="'$(Configuration)' != 'Debug'">All</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\OCCT_NETWrapper\OCCT_NETWrapper.csproj" />
  </ItemGroup>

  <Target Name="PreBuild" BeforeTargets="PreBuildEvent">
    <Exec Command="xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\LNLib\bin\$(Configuration)\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\angle-gles2-2.1.0-vc14-64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\ffmpeg-3.3.4-64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\freeimage-3.18.0-x64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\freetype-2.13.3-x64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\gl2ps-1.3.8-vc14-64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\jemalloc-vc14-64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\lzma-5.2.2-vc14-64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\msvc-vc14-64\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\openvr-1.14.15-64\bin\win64\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\tbb-2021.13.0-x64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\tcltk-8.6.15-x64\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\3rdparty-vc14-64\zlib-1.2.8-vc14-644\bin\*.dll&quot; &quot;$(OutDir)&quot;&#xD;&#xA;xcopy /Y &quot;$(ProjectDir)..\..\thirdparty\OCCT\win64\vc14\bin\*.dll&quot; &quot;$(OutDir)&quot;" />
  </Target>
</Project>
